# ====================================================
# CyberShield AI Configuration Environment
# ====================================================

# Google Gemini API key (Required if not deploying to GCP / Vertex AI Runtime)
GEMINI_API_KEY=your_gemini_api_key_here

# GCP Project parameters (Required for Vertex AI / Agent Runtime)
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-east1
# GOOGLE_GENAI_USE_VERTEXAI=True

# CORS origins allow rules (comma separated)
ALLOW_ORIGINS=*
